<Window x:Class="MyitCenter.TrayTicketTool.Views.TicketListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="myit.center - Meine Tickets"
        Width="550" Height="450"
        MinWidth="450" MinHeight="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Meine Tickets"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock x:Name="SubtitleText" FontSize="12"
                       Foreground="{StaticResource SubtextBrush}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Ticket Liste -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="4">
            <ListBox x:Name="TicketList" BorderThickness="0" Background="Transparent"
                     MouseDoubleClick="TicketList_MouseDoubleClick"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding TicketNumber}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="#2980B9" />
                                    <TextBlock Text="{Binding ReplyIndicator}" FontSize="13"
                                               Foreground="#E67E22" Margin="8,0,0,0" />
                                </StackPanel>

                                <Border Grid.Row="0" Grid.Column="1"
                                        Background="{Binding StatusBackground}"
                                        CornerRadius="3" Padding="8,2">
                                    <TextBlock Text="{Binding StatusLabel}" FontSize="11"
                                               Foreground="White" />
                                </Border>

                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding Subject}" FontSize="12"
                                           Foreground="#555" Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Keine Tickets Info -->
        <TextBlock x:Name="EmptyText" Grid.Row="1"
                   Text="Keine offenen Tickets vorhanden."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource SubtextBrush}" FontSize="14"
                   Visibility="Collapsed" />

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="ReplyButton" Content="Ticket oeffnen"
                    Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                    Click="Reply_Click" IsEnabled="False" />
            <Button Content="Schliessen" Padding="16,8" Cursor="Hand"
                    Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
