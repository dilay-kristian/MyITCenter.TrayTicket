<Window x:Class="MyitCenter.TrayTicketTool.Views.TicketListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="myit.center - Meine Tickets"
        Width="560" Height="480"
        MinWidth="460" MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None" AllowsTransparency="True">

    <Border CornerRadius="12" Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="0" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Meine Tickets" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock x:Name="SubtitleText" FontSize="11"
                                   Foreground="{StaticResource SubtextBrush}" Margin="12,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Background="Transparent" Foreground="{StaticResource SubtextBrush}"
                            FontSize="14" Padding="8,4"
                            Click="Close_Click" />
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16,12,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Ticket Liste -->
                <ListBox x:Name="TicketList" Grid.Row="0" BorderThickness="0"
                         Background="Transparent"
                         MouseDoubleClick="TicketList_MouseDoubleClick"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                                    Padding="14,12" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding TicketNumber}" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource AccentLightBrush}" />
                                        <TextBlock Text="{Binding ReplyIndicator}" FontSize="12"
                                                   Foreground="{StaticResource WarningBrush}" Margin="10,0,0,0" />
                                    </StackPanel>

                                    <Border Grid.Row="0" Grid.Column="1"
                                            Background="{Binding StatusBackground}"
                                            CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="{Binding StatusLabel}" FontSize="10"
                                                   Foreground="White" FontWeight="SemiBold" />
                                    </Border>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding Subject}" FontSize="12"
                                               Foreground="{StaticResource SubtextBrush}" Margin="0,6,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Leer -->
                <TextBlock x:Name="EmptyText" Grid.Row="0"
                           Text="Keine offenen Tickets vorhanden."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource SubtextBrush}" FontSize="14"
                           Visibility="Collapsed" />

                <!-- Buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button x:Name="ReplyButton" Content="Ticket öffnen"
                            Style="{StaticResource AccentButton}"
                            Margin="0,0,8,0"
                            Click="Reply_Click" IsEnabled="False" />
                    <Button Content="Schließen"
                            Style="{StaticResource SecondaryButton}"
                            Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
