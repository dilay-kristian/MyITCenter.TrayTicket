<Window x:Class="MyitCenter.TrayTicketTool.Views.TicketReplyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="myit.center - Nachricht hinzufügen"
        Width="520" Height="550"
        MinWidth="420" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="HeaderText" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock x:Name="SubjectText" FontSize="12"
                       Foreground="{StaticResource SubtextBrush}" Margin="0,4,0,0"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- Kommentar -->
        <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Nachricht (optional):" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                <TextBox x:Name="MessageBox" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="80" FontSize="13"
                         Padding="8,6"
                         BorderBrush="#DDD" BorderThickness="1"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>
        </Border>

        <!-- Screenshot Section -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Screenshot-Modus (optional):" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RegionMode" Content="Bereich" IsChecked="True"
                                 Margin="0,0,16,0" VerticalContentAlignment="Center" />
                    <RadioButton x:Name="FullScreenMode" Content="Vollbild"
                                 Margin="0,0,16,0" VerticalContentAlignment="Center" />
                    <RadioButton x:Name="WindowMode" Content="Fenster"
                                 VerticalContentAlignment="Center" />
                </StackPanel>

                <Button x:Name="CaptureButton" Content="Screenshot aufnehmen"
                        Padding="16,6" HorizontalAlignment="Left" Cursor="Hand"
                        Click="Capture_Click" />
            </StackPanel>
        </Border>

        <!-- Screenshot Preview -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}" CornerRadius="6" Padding="8" Margin="0,0,0,12">
            <Grid>
                <TextBlock x:Name="NoScreenshotText"
                           Text="Kein Screenshot (optional)"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource SubtextBrush}" FontSize="13" />
                <Image x:Name="ScreenshotPreview" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality" />
            </Grid>
        </Border>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="4" FontSize="12"
                   Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,8" />

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                    Click="Cancel_Click" />
            <Button x:Name="SendButton" Content="Absenden" Padding="16,8" Cursor="Hand"
                    Click="Send_Click" />
        </StackPanel>
    </Grid>
</Window>
