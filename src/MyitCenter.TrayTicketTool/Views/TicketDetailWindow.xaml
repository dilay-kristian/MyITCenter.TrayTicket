<Window x:Class="MyitCenter.TrayTicketTool.Views.TicketDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="myit.center - Ticket Details"
        Width="580" Height="650"
        MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">

    <DockPanel Margin="20">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock x:Name="TicketNumberText" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" />
            <TextBlock x:Name="SubjectText" FontSize="13"
                       Foreground="{StaticResource TextBrush}" Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Reply-Bereich unten -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CardBrush}"
                CornerRadius="6" Padding="12" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Antworten:" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />

                <TextBox x:Name="ReplyBox" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="60" FontSize="13" Padding="8,6"
                         BorderBrush="#DDD" BorderThickness="1"
                         VerticalScrollBarVisibility="Auto" />

                <!-- Anhaenge -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Screenshot" Padding="10,4" FontSize="12"
                            Margin="0,0,8,0" Cursor="Hand"
                            Click="Screenshot_Click" />
                    <Button Content="Datei anhaengen..." Padding="10,4" FontSize="12"
                            Margin="0,0,8,0" Cursor="Hand"
                            Click="AttachFile_Click" />
                </StackPanel>

                <TextBlock x:Name="AttachmentList" FontSize="11"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,4,0,0"
                           TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <TextBlock x:Name="StatusText" FontSize="12"
                               Foreground="{StaticResource SubtextBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button x:Name="SendButton" Content="Absenden" Padding="16,6"
                            FontWeight="SemiBold" Cursor="Hand"
                            Click="Send_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Nachrichten-Liste (Chat) -->
        <Border Background="{StaticResource CardBrush}" CornerRadius="6" Padding="4">
            <ScrollViewer x:Name="MessagesScroll" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="MessagesPanel" />
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
