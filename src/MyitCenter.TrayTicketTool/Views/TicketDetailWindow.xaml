<Window x:Class="MyitCenter.TrayTicketTool.Views.TicketDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="myit.center - Ticket Details"
        Width="600" Height="680"
        MinWidth="500" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None" AllowsTransparency="True">

    <Border CornerRadius="12" Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="0" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="TicketNumberText" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentLightBrush}" />
                        <TextBlock Text=" — " Foreground="{StaticResource SubtextBrush}" FontSize="13"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="SubjectText" FontSize="13"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="350" />
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Background="Transparent" Foreground="{StaticResource SubtextBrush}"
                            FontSize="14" Padding="8,4"
                            Click="CloseWindow_Click" />
                </Grid>
            </Border>

            <!-- Content -->
            <DockPanel Grid.Row="1" Margin="16,12,16,16">
                <!-- Reply-Bereich unten -->
                <Border DockPanel.Dock="Bottom" Background="{StaticResource CardBrush}"
                        CornerRadius="10" Padding="14" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBox x:Name="ReplyBox" AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="60"
                                 VerticalScrollBarVisibility="Auto" />

                        <Grid Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Screenshot" Padding="10,6" FontSize="12"
                                        Margin="0,0,6,0"
                                        Click="Screenshot_Click" />
                                <Button Content="Datei" Padding="10,6" FontSize="12"
                                        Click="AttachFile_Click" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="StatusText" FontSize="11"
                                           Foreground="{StaticResource SubtextBrush}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" />
                                <Button x:Name="SendButton" Content="Senden"
                                        Style="{StaticResource AccentButton}"
                                        Padding="16,8" FontSize="13"
                                        Click="Send_Click" />
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="AttachmentList" FontSize="11"
                                   Foreground="{StaticResource SubtextBrush}" Margin="0,6,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Nachrichten -->
                <ScrollViewer x:Name="MessagesScroll" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="MessagesPanel" />
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </Border>
</Window>
