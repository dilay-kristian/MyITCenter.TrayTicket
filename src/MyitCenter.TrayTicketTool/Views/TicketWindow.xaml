<Window x:Class="MyitCenter.TrayTicketTool.Views.TicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="myit.center - Ticket erstellen"
        Width="560" Height="700"
        MinWidth="460" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None" AllowsTransparency="True">

    <Border CornerRadius="12" Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="0" Color="Black" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <TextBlock Text="Ticket erstellen"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" />
                    <Button Content="✕" HorizontalAlignment="Right"
                            Background="Transparent" Foreground="{StaticResource SubtextBrush}"
                            FontSize="14" Padding="8,4"
                            Click="Close_Click" />
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="24,16,24,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- User Info -->
                    <Border Grid.Row="0" Background="{StaticResource CardBrush}"
                            CornerRadius="10" Padding="16,12" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="36" Height="36" Fill="{StaticResource AccentBrush}" Margin="0,0,12,0">
                                <Ellipse.OpacityMask>
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <TextBlock Text="👤" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Ellipse.OpacityMask>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUsername}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                                             VerticalAlignment="Center"
                                             Fill="{Binding ConnectionDot}" />
                                    <TextBlock Text="{Binding ConnectionStatus}" FontSize="11"
                                               Foreground="{StaticResource SubtextBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Screenshot Section -->
                    <Border Grid.Row="1" Background="{StaticResource CardBrush}"
                            CornerRadius="10" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Screenshot" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <RadioButton Content="Bereich"
                                             IsChecked="{Binding IsRegionMode}"
                                             Margin="0,0,20,0" VerticalContentAlignment="Center" />
                                <RadioButton Content="Vollbild"
                                             IsChecked="{Binding IsFullScreenMode}"
                                             Margin="0,0,20,0" VerticalContentAlignment="Center" />
                                <RadioButton Content="Fenster"
                                             IsChecked="{Binding IsWindowMode}"
                                             VerticalContentAlignment="Center" />
                            </StackPanel>

                            <Button Content="Screenshot aufnehmen"
                                    Command="{Binding CaptureScreenshotCommand}"
                                    Style="{StaticResource AccentButton}"
                                    HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <!-- Screenshot Preview -->
                    <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                            CornerRadius="10" Padding="8" Margin="0,0,0,12"
                            MinHeight="150">
                        <Grid>
                            <TextBlock Text="Noch kein Screenshot aufgenommen"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource SubtextBrush}" FontSize="13"
                                       Visibility="{Binding NoScreenshotVisibility}" />
                            <Image Source="{Binding ScreenshotPreview}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Grid>
                    </Border>

                    <!-- Description -->
                    <Border Grid.Row="3" Background="{StaticResource CardBrush}"
                            CornerRadius="10" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Problembeschreibung" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="100"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>

                    <!-- System Info -->
                    <Expander Grid.Row="4" Header="Systeminformationen" Margin="0,0,0,16"
                              Foreground="{StaticResource SubtextBrush}" FontSize="12">
                        <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                                Padding="14" Margin="0,6,0,0">
                            <TextBlock Text="{Binding SystemInfoSummary}" FontSize="12"
                                       Foreground="{StaticResource TextBrush}" />
                        </Border>
                    </Expander>

                    <!-- Buttons + Status -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource SubtextBrush}" FontSize="12"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="1" Content="Abbrechen"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,10,0" />

                        <Button Grid.Column="2" Content="Ticket erstellen"
                                Command="{Binding SubmitTicketCommand}"
                                Style="{StaticResource AccentButton}" />
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
