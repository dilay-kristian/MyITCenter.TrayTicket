<Window x:Class="MyitCenter.TrayTicketTool.Views.WindowSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fenster auswaehlen"
        Width="450" Height="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Bitte waehlen Sie das Fenster aus:"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource TextBrush}"
                   Margin="0,0,0,12" />

        <ListBox Grid.Row="1" x:Name="WindowList"
                 DisplayMemberPath="DisplayText"
                 FontSize="13"
                 BorderBrush="#DDD" BorderThickness="1"
                 MouseDoubleClick="WindowList_MouseDoubleClick" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Abbrechen" Padding="16,6" Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Content="Auswaehlen" Padding="16,6"
                    Click="Select_Click" />
        </StackPanel>
    </Grid>
</Window>
