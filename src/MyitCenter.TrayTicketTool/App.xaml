<Application x:Class="MyitCenter.TrayTicketTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown"
             Startup="Application_Startup">
    <Application.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#2980B9" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#3498DB" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F6FA" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextBrush" Color="#2C3E50" />
        <SolidColorBrush x:Key="SubtextBrush" Color="#7F8C8D" />

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#2C3E50" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#2C3E50" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#2C3E50" />
        </Style>
    </Application.Resources>
</Application>
